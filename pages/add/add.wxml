<view class="container">
  <view class="title">➕ 添加新植物</view>
  
  <!-- 拍照按钮 -->
  <view class="camera-btn" bindtap="chooseImage">
    <image wx:if="{{photoPath}}" src="{{photoPath}}" mode="aspectFill" class="preview-img"></image>
    <view wx:else class="camera-placeholder">
      <text class="camera-icon">📷</text>
      <text class="camera-text">点击拍照</text>
    </view>
  </view>

  <view class="form">
    <!-- 搜索+选择植物 -->
    <view class="form-item">
      <text class="label">🌸 选择植物（共{{filteredList.length}}种）</text>
      <view class="plant-search-box">
        <input class="plant-search-input" placeholder="🔍 输入花名搜索..." value="{{searchText}}" bindinput="onSearchInput" bindfocus="onSearchFocus" bindblur="onSearchBlur"/>
        <scroll-view scroll-y class="plant-dropdown {{showDropdown ? 'show' : ''}}" bindscroll="onDropdownScroll" style="height: {{showDropdown && filteredList.length > 0 ? 300 : 0}}rpx">
          <view wx:for="{{filteredList}}" wx:key="index" class="plant-option" bindtap="onSelectPlant" data-index="{{index}}">
            {{item.name}}
          </view>
        </scroll-view>
      </view>
    </view>

    <!-- 花名输入框 -->
    <view class="form-item">
      <text class="label">🌸 花名 *</text>
      <input class="input" placeholder="如：绿萝、吊兰" value="{{name}}" bindinput="onNameInput"/>
    </view>

    <view class="form-item">
      <text class="label">📍 摆放位置</text>
      <input class="input" placeholder="如：客厅、卧室" value="{{location}}" bindinput="onLocationInput"/>
    </view>

    <view class="form-item">
      <text class="label">💧 浇水频率</text>
      <view class="tip">根据当地一周天气预报估算</view>
      <picker bindchange="onWaterFreqChange" value="{{waterFreqIndex}}" range="{{waterFreqList}}">
        <view class="picker">{{waterFreqList[waterFreqIndex]}}</view>
      </picker>
    </view>

    <view class="form-item">
      <text class="label">☀️ 光照要求</text>
      <input class="input" value="{{light}}" bindinput="onLightInput"/>
    </view>

    <view class="form-item">
      <text class="label">🌡️ 温度要求</text>
      <input class="input" value="{{temperature}}" bindinput="onTempInput"/>
    </view>

    <view class="form-item">
      <text class="label">🌱 施肥方法</text>
      <input class="input" value="{{fertilizer}}" bindinput="onFertilizerInput"/>
    </view>

    <view class="form-item">
      <text class="label">💨 注意事项</text>
      <input class="input" value="{{humidity}}" bindinput="onHumidityInput"/>
    </view>

    <view class="form-item toxic-item">
      <text class="label">☠️ 是否有毒：</text>
      <text class="toxic-text">{{toxicityLevel || '无刺激'}}</text>
    </view>
  </view>

  <button class="save-btn" bindtap="savePlant">💾 保存</button>
</view>
