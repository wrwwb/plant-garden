page {
  background: linear-gradient(135deg, #F5F0F0 0%, #E8E4E8 50%, #E0E4E0 100%);
  min-height: 100vh;
}

.container { padding: 30rpx; }

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 30rpx;
}

.camera-btn {
  width: 100%;
  height: 350rpx;
  background: linear-gradient(135deg, #A8D8EA 0%, #89CFF0 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.camera-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #2C5F7C;
}

.camera-icon { font-size: 80rpx; }
.camera-text { font-size: 28rpx; margin-top: 10rpx; }
.preview-img { width: 100%; height: 100%; border-radius: 20rpx; }

.form {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
}

.form-item { margin-bottom: 24rpx; }

.label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.tip {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.recommended {
  font-size: 24rpx;
  color: #4CAF50;
  font-weight: bold;
}

.input, .picker {
  border: 1rpx solid #eee;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  background: #FAFAFA;
}

/* 搜索框+下拉列表 */
.plant-search-box {
  position: relative;
}

.plant-search-input {
  border: 1rpx solid #ddd;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  background: #f9f9f9;
}

.plant-dropdown {
  position: absolute;
  top: 100%;
  left: 0;
  right: 0;
  background: white;
  border: 1rpx solid #ddd;
  border-radius: 12rpx;
  margin-top: 8rpx;
  z-index: 100;
  display: none;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.plant-dropdown.show {
  display: block;
}

.plant-option {
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  border-bottom: 1rpx solid #f0f0f0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.plant-option:last-child {
  border-bottom: none;
}

.plant-option.selected {
  background: #f5f0f5;
}

.toxic-badge {
  font-size: 24rpx;
}

.toxic-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.toxic-text {
  font-size: 28rpx;
  font-weight: bold;
}

.toxic-yes {
  color: #e74c3c;
}

.toxic-no {
  color: #27ae60;
}

.save-btn {
  background: linear-gradient(135deg, #C8A2C8 0%, #B89BB8 100%);
  color: white;
  border: none;
  border-radius: 50rpx;
  padding: 25rpx;
  font-size: 32rpx;
  margin-top: 40rpx;
  width: 45%;
  display: inline-block;
  margin-right: 5%;
}

.save-btn:last-child {
  margin-right: 0;
}
