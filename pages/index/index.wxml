<view class="container">
  <!-- 顶部标题栏 -->
  <view class="page-header">
    <text class="header-title">{{currentUserId || '未设置用户'}}的 🌸 花园浇水助手</text>
  </view>

  <!-- 天气提示 -->
  <view class="weather-banner">
    <text class="icon">{{weatherIcon}}</text>
    <text>{{localWeather}}</text>
    <text class="city-name" bindtap="editAddress">📍 {{cityName || '点击设置地址'}}</text>
    <view class="init-link" bindtap="goToInit">🔧</view>
  </view>

  <!-- 统计 -->
  <view class="stats-grid">
    <view class="stat-card">
      <view class="stat-number">{{plants.length}}</view>
      <view class="stat-label">🌸 植物种类</view>
    </view>
    <view class="stat-card" bindtap="showNeedsWater">
      <view class="stat-number">{{needWaterCount}}</view>
      <view class="stat-label">💧 待浇水</view>
    </view>
    <view class="stat-card" bindtap="showNeedsFertilizer">
      <view class="stat-number">{{needFertilizerCount}}</view>
      <view class="stat-label">🌱 待施肥</view>
    </view>
  </view>

  <!-- 添加按钮 -->
  <view class="add-btn" bindtap="goToAdd">
    <text class="btn-icon">➕</text>
    <text class="btn-text">添加植物</text>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading"><text>加载中...</text></view>

  <!-- 错误提示 -->
  <view wx:elif="{{error}}" class="error"><text>⚠️ {{error}}</text></view>

  <!-- 空状态 -->
  <view wx:elif="{{!loading && !error && plants.length === 0}}" class="empty-state">
    <view class="empty-icon">🌱</view>
    <view class="empty-title">还没有植物呢</view>
    <view class="empty-desc">点击下方「添加植物」开始记录你的植物吧~</view>
  </view>

  <!-- 植物列表（分组卡片） -->
  <view wx:else class="plant-scroll">
    <view class="section">
      <view class="section-title">🌿 我的植物们</view>

      <!-- 快速导航 -->
      <view class="plant-nav">
        <view wx:for="{{plants}}" wx:key="name" class="plant-nav-item" bindtap="scrollToPlant" data-index="{{index}}">
          {{item.rawName}}
        </view>
      </view>

      <!-- 植物卡片 -->
      <view wx:for="{{plants}}" wx:key="name" id="plant-{{index}}" class="plant-card {{item.needWater ? 'urgent' : ''}}" style="background: {{item.cardColor || 'white'}}">
      <view class="plant-header">
        <view class="plant-title">
          <text class="plant-name">{{item.name}}</text>
          <text wx:if="{{item.toxicityLevel !== '无刺激'}}" class="plant-poison toxic-light">⚠️ {{item.toxicityLevel}}</text>
        </view>
        <view wx:if="{{item.scientificName}}" class="plant-sci">{{item.scientificName}}</view>
        <view class="plant-location">📍 {{item.location}}{{item.count > 1 ? ' (共' + item.count + '盆)' : ''}}</view>
        <view wx:if="{{item.toxicitySource}}" class="toxic-reason">☠️ {{item.toxicitySource}}</view>
      </view>

      <!-- 简介 -->
      <view wx:if="{{item.plantDesc}}" class="plant-desc">{{item.plantDesc}}</view>

      <!-- 资料标签 -->
      <view class="plant-detail-tags">
        <view wx:if="{{item.waterFrequency}}" class="detail-tag">💧 {{item.waterFrequency}}</view>
        <view wx:if="{{item.light}}" class="detail-tag">☀️ 光照：{{item.light}}</view>
        <view wx:if="{{item.temperature}}" class="detail-tag">🌡️ 温度：{{item.temperature}}</view>
        <view wx:if="{{item.fertilizer}}" class="detail-tag">🌱 施肥：{{item.fertilizer}}</view>
        <view wx:if="{{item.humidity}}" class="detail-tag">💨 湿度：{{item.humidity}}</view>
        <view wx:if="{{item.origin}}" class="detail-tag">🌏 {{item.origin}}</view>
      </view>

      <!-- 时间信息 -->
      <view class="time-section">
        <view class="time-row">
          <view class="time-item half">
            <view class="time-label">💧 上次浇水</view>
            <picker mode="date" value="{{item.lastWaterDate}}" bindchange="editLastWater" data-index="{{index}}" data-id="{{item.recordIds[0]}}">
              <view class="time-value time-edit">{{item.lastWaterTime}} ✏️</view>
            </picker>
          </view>
          <view class="time-item half">
            <view class="time-label">🌱 上次施肥</view>
            <view class="time-value">{{item.lastFertilizerTime}}</view>
          </view>
        </view>
        <view class="time-row">
          <view class="time-item half">
            <view class="time-label">💧 下次浇水</view>
            <view class="time-value {{item.needWater ? 'urgent' : ''}}">{{item.nextWaterTime}}</view>
          </view>
          <view class="time-item half">
            <view class="time-label">🌱 下次施肥</view>
            <view class="time-value {{item.needFertilizer ? 'urgent' : ''}}">{{item.nextFertilizerTime}}</view>
          </view>
        </view>
      </view>

      <!-- 操作按钮（批量操作） -->
      <view class="plant-actions">
        <button class="btn water-btn" catchtap="waterPlant" data-recordids="{{item.recordIds}}" data-name="{{item.rawName}}">💧 浇水</button>
        <button class="btn fertilizer-btn" catchtap="fertilizePlant" data-recordids="{{item.recordIds}}" data-name="{{item.rawName}}">🌱 施肥</button>
      </view>

      <!-- 删除按钮 -->
      <view class="delete-btn" catchtap="showDeleteModal" data-index="{{index}}">✕</view>
      <view class="back-top-btn" catchtap="scrollToTop">↑</view>
    </view>
    </view>
  </view>

  <!-- 删除确认弹窗 -->
  <view wx:if="{{showDelete}}" class="modal-mask" bindtap="closeDeleteModal">
    <view class="modal-sheet" catchtap="preventBubble">
      <view class="sheet-header">
        <text class="sheet-title">{{deletePlantName}} 要删哪几盆？</text>
        <text class="sheet-close" bindtap="closeDeleteModal">✕</text>
      </view>
      <scroll-view class="sheet-body" scroll-y>
        <view wx:for="{{deleteItems}}" wx:key="recordId" class="sheet-row" bindtap="toggleDeleteItem" data-index="{{index}}">
          <view class="row-num {{item._selected ? 'active' : ''}}">{{index + 1}}</view>
          <text class="row-name">{{item.location}}</text>
          <text class="row-arrow {{item._selected ? 'up' : ''}}">›</text>
        </view>
      </scroll-view>
      <view class="sheet-footer">
        <button class="del-btn" bindtap="deleteSelectedItems">删除 {{deleteCount ? '(' + deleteCount + ')' : ''}}</button>
      </view>
    </view>
  </view>
</view>
