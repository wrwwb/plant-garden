page {
  background: linear-gradient(135deg, #F5F0F0 0%, #E8E4E8 50%, #E0E4E0 100%);
  min-height: 100vh;
}

.container {
  padding: 20rpx;
}

.page-header {
  text-align: center;
  padding: 16rpx 0 12rpx;
}

.header-user {
  display: block;
  font-size: 36rpx;
  color: #4A6741;
  margin-bottom: 4rpx;
}

.header-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #4A6741;
}

.weather-banner {
  background: linear-gradient(135deg, #A8B5A8 0%, #95A595 100%);
  color: white;
  padding: 24rpx;
  border-radius: 16rpx;
  text-align: center;
  font-size: 28rpx;
  position: relative;
}

.init-link {
  position: absolute;
  right: 12rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 36rpx;
  opacity: 0.9;
  z-index: 2;
  padding: 8rpx;
}

.user-setting {
  background: white;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
  text-align: center;
  margin: 20rpx 0;
}

.stats-grid {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.stat-card {
  flex: 1;
  background: white;
  border-radius: 16rpx;
  padding: 20rpx;
  text-align: center;
  margin: 0 8rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.stat-number {
  font-size: 44rpx;
  font-weight: bold;
  color: #C8A2C8;
}

.stat-label {
  font-size: 22rpx;
  color: #666;
  margin-top: 8rpx;
}

.add-btn {
  width: 100%;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 15rpx;
  padding: 25rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #C8A2C8 0%, #B89BB8 100%);
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  margin: 20rpx 0;
}

.btn-icon { font-size: 36rpx; }
.btn-text { font-size: 28rpx; }

.loading {
  text-align: center;
  padding: 60rpx;
  color: #999;
}

.error {
  text-align: center;
  padding: 40rpx;
  color: #E57373;
  background: #FFEBEE;
  border-radius: 16rpx;
  margin: 20rpx 0;
}

.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  background: white;
  border-radius: 20rpx;
  margin-top: 20rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #888;
  line-height: 1.6;
}

.plant-scroll {
  margin-top: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #4A4A4A;
  margin-bottom: 20rpx;
}

.plant-card {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  position: relative;
  transition: transform 0.2s;
}

.plant-card.urgent {
  border-left: 6rpx solid #E8A4A4;
}

.plant-header {
  margin-bottom: 16rpx;
}

.plant-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.plant-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.plant-poison {
  font-size: 20rpx;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
}

.toxic-light {
  background: #FFF8E1;
  color: #F57F17;
}

.toxic-medium {
  background: #FFF3E0;
  color: #E65100;
}

.toxic-strong {
  background: #FFEBEE;
  color: #C62828;
}

.plant-location {
  font-size: 24rpx;
  color: #888;
}

.plant-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
  margin-top: 10rpx;
  padding: 10rpx 0;
  border-top: 1rpx dashed #e0e0e0;
  border-bottom: 1rpx dashed #e0e0e0;
}

.toxic-reason {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

.plant-info {
  background: #FAFAFA;
  padding: 16rpx;
  border-radius: 12rpx;
  margin-top: 12rpx;
}

.info-line {
  font-size: 24rpx;
  color: #555;
  line-height: 1.8;
}

.time-section {
  padding: 12rpx 0;
  border-top: 1rpx dashed #eee;
  border-bottom: 1rpx dashed #eee;
  margin-top: 12rpx;
}

.time-item {
  text-align: center;
  flex: 1;
}

.time-label {
  font-size: 22rpx;
  color: #999;
}

.time-value {
  font-size: 26rpx;
  color: #333;
  margin-top: 4rpx;
}

.time-value.urgent {
  color: #E57373;
  font-weight: bold;
}

.plant-actions {
  display: flex;
  gap: 16rpx;
  margin: 20rpx 0;
}

.btn {
  flex: 1;
  border: none;
  border-radius: 24rpx;
  font-size: 26rpx;
  padding: 14rpx 0;
}

.water-btn {
  background: #E3F2FD;
  color: #1565C0;
}

.fertilizer-btn {
  background: #E8F5E9;
  color: #2E7D32;
}

.plant-detail {
  border-top: 1rpx solid #eee;
  margin: 20rpx 0;
  padding-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.detail-item {
  font-size: 22rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 4rpx 12rpx;
}

.city-name {
  font-size: 22rpx;
  color: #888;
  margin-left: 8rpx;
}

.delete-btn {
  position: absolute;
  right: 16rpx;
  top: 16rpx;
  width: 60rpx;
  height: 60rpx;
  background: rgba(0,0,0,0.08);
  color: #666;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 32rpx;
  z-index: 2;
}

.plant-sci {
  font-size: 23rpx;
  color: #888;
  font-style: italic;
  margin-top: 4rpx;
  margin-bottom: 4rpx;
}

.plant-detail-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 8rpx;
}

.detail-tag {
  font-size: 23rpx;
  color: #2e7d32;
  background: #e8f5e9;
  border: 1rpx solid #81c784;
  border-radius: 10rpx;
  padding: 6rpx 16rpx;
  font-weight: 500;
}

.time-edit {
  text-decoration: underline;
  color: #1565C0;
}

.time-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 8rpx;
}
.time-row:last-child {
  margin-bottom: 0;
}
.time-item.half {
  flex: 1;
}

.plant-nav {
  display: flex;
  flex-wrap: nowrap;
  flex-wrap: wrap;
  
  margin-bottom: 16rpx;
  padding-bottom: 8rpx;
  -webkit-overflow-scrolling: touch;
}
.plant-nav::-webkit-scrollbar {
  display: none;
}
.plant-nav-item {
  display: inline-block;
  flex-shrink: 0;
  padding: 8rpx 20rpx;
  background: #f0f0f0;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #666;
  margin-right: 12rpx;
  border: 1rpx solid #ddd;
}

.init-link {
  position: absolute;
  right: 12rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 36rpx;
  opacity: 0.9;
  z-index: 2;
  padding: 8rpx;
}

.user-setting {
  background: white;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #666;
  text-align: center;
  margin: 12rpx auto;
  display: inline-block;
  width: auto;
}

.weather-user {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
  margin-left: 12rpx;
}

.back-top-btn {
  position: absolute;
  right: 80rpx;
  top: 16rpx;
  width: 60rpx;
  height: 60rpx;
  background: rgba(200,162,200,0.15);
  color: #C8A2C8;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 32rpx;
  border: 1rpx solid #ddd;
  z-index: 2;
}

/* 分组详情弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 999;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}
.modal-content {
  background: white;
  border-radius: 24rpx 24rpx 0 0;
  width: 100%;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}
.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
  flex-shrink: 0;
}
.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}
.modal-close {
  font-size: 36rpx;
  color: #999;
  padding: 10rpx;
}
.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx 30rpx;
}
.group-record-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.group-record-item:last-child {
  border-bottom: none;
}
.group-record-info {
  display: flex;
  flex-direction: column;
  flex: 1;
}
.group-record-name {
  font-size: 28rpx;
  color: #333;
}
.group-record-time {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}
.group-record-btns {
  display: flex;
  gap: 16rpx;
}
.btn.small {
  padding: 8rpx 20rpx;
  font-size: 24rpx;
}
.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #eee;
  flex-shrink: 0;
}
.modal-footer .btn {
  flex: 1;
  font-size: 28rpx;
  padding: 16rpx;
}

/* 删除勾选样式 */
.group-record-check {
  margin-right: 16rpx;
}
.check-circle {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid #ccc;
  background: #fff;
  transition: all 0.2s;
}
.check-circle.checked {
  border-color: #4CAF50;
  background: #4CAF50;
}
.group-record-item.selected .group-record-info {
  opacity: 0.7;
}
.group-record-item.selected .group-record-name {
  text-decoration: line-through;
  color: #999;
}
