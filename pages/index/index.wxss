page {
  background: linear-gradient(135deg, #F5F0F0 0%, #E8E4E8 50%, #E0E4E0 100%);
  min-height: 100vh;
}

.container {
  padding: 20rpx;
}

.weather-banner {
  background: linear-gradient(135deg, #A8B5A8 0%, #95A595 100%);
  color: white;
  padding: 24rpx;
  border-radius: 16rpx;
  text-align: center;
  font-size: 28rpx;
  margin-bottom: 16rpx;
}

.user-setting {
  background: white;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  color: #666;
  text-align: center;
}

.stats-grid {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.add-btn-group {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  background: white;
  border-radius: 20rpx;
  margin-top: 20rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #888;
  line-height: 1.6;
}

.add-btn {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 15rpx;
  padding: 25rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #C8A2C8 0%, #B89BB8 100%);
  color: white;
  font-size: 32rpx;
  font-weight: bold;
}

.btn-icon { font-size: 36rpx; }
.btn-text {}

.stat-card {
  flex: 1;
  background: white;
  border-radius: 16rpx;
  padding: 20rpx;
  text-align: center;
  margin: 0 8rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.stat-number {
  font-size: 44rpx;
  font-weight: bold;
  color: #C8A2C8;
}

.stat-label {
  font-size: 22rpx;
  color: #666;
  margin-top: 8rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #4A4A4A;
  margin-bottom: 20rpx;
}

.debug-info {
  padding: 40rpx;
  text-align: center;
  color: #999;
}

.plant-scroll {
  height: calc(100vh - 380rpx);
}

.plant-card {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  position: relative;
  transition: transform 0.2s;
}

.plant-card.urgent {
  border-left: 6rpx solid #E8A4A4;
}

.delete-btn {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 160rpx;
  background: #e74c3c;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 0 16rpx 16rpx 0;
  font-size: 26rpx;
}

.plant-header {
  margin-bottom: 16rpx;
}

.plant-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.plant-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.plant-poison {
  font-size: 20rpx;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
}
.plant-poison.轻微刺激 { background: #FFF8E1; color: #F57F17; }
.plant-poison.中度刺激 { background: #FFF3E0; color: #E65100; }
.plant-poison.强烈刺激 { background: #FFEBEE; color: #C62828; }

.toxic-info {
  color: #E65100 !important;
  font-size: 22rpx !important;
  background: #FFF8E1;
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
  margin-top: 8rpx;
  line-height: 1.5 !important;
}

.plant-location {
  font-size: 24rpx;
  color: #888;
}

.plant-info {
  background: #FAFAFA;
  padding: 16rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.info-line {
  font-size: 24rpx;
  color: #555;
  line-height: 1.8;
}

.time-section {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-top: 1rpx dashed #eee;
  border-bottom: 1rpx dashed #eee;
  margin-bottom: 16rpx;
}

.time-item {
  text-align: center;
  flex: 1;
}

.time-label {
  font-size: 22rpx;
  color: #999;
}

.time-value {
  font-size: 26rpx;
  color: #333;
  margin-top: 4rpx;
}

.time-value.urgent {
  color: #E57373;
  font-weight: bold;
}

.plant-actions {
  display: flex;
  gap: 16rpx;
}

.btn {
  flex: 1;
  border: none;
  border-radius: 24rpx;
  font-size: 26rpx;
  padding: 14rpx 0;
}

.water-btn {
  background: #E3F2FD;
  color: #1565C0;
}

.fertilizer-btn {
  background: #E8F5E9;
  color: #2E7D32;
}
