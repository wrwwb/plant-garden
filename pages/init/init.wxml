<!--pages/init/init.wxml-->
<view class="container">
  <view class="header">
    <text class="title">🌱 上传我的植物</text>
  </view>
  
  <view class="description">
    <text>点击下方按钮，将植物数据批量上传到云数据库</text>
  </view>

  <button class="upload-btn" bindtap="uploadMyPlants">🌱 上传我的植物</button>
  
  <view class="description">
    <text>或点击下方按钮直接从云函数上传</text>
  </view>

  <button class="cloud-upload-btn" bindtap="cloudUpload">☁️ 云函数批量上传</button>

  <view class="description">
    <text>点击下方按钮，为已有植物补全简介</text>
  </view>

  <button class="desc-btn" bindtap="fillDescriptions">📝 补全植物简介</button>

  <view id="upload-log" class="log-area">
    <!-- 上传日志 -->
  </view>
</view>
