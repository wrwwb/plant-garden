/* pages/init/init.wxss */
.container {
  padding: 20px;
}
.header {
  margin-bottom: 15px;
}
.title {
  font-size: 20px;
  font-weight: bold;
  color: #333;
}
.description {
  margin-bottom: 15px;
  color: #666;
}
.upload-btn, .cloud-upload-btn {
  background-color: #4CAF50;
  color: white;
  padding: 10px 20px;
  border: none;
  border-radius: 4px;
  font-size: 16px;
  cursor: pointer;
  margin-bottom: 10px;
}
.cloud-upload-btn {
  background-color: #2196F3;
}
.log-area {
  background-color: #f9f9f9;
  padding: 10px;
  border-radius: 4px;
  margin-top: 10px;
  white-space: pre-wrap;
  font-family: monospace;
  font-size: 12px;
  color: #333;
}
